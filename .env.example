# LifeOS Pro — Configuración de Variables de Entorno (Ejemplo)

# Entorno de la aplicación (development | production)
VITE_APP_ENV=development

# Configuración de Sincronización en la Nube (Opcional - Supabase)
# Copia este archivo como '.env' e introduce tus credenciales de Supabase
# para habilitar la sincronización en la nube en el plan Premium.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
